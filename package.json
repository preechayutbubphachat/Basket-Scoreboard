{
  "name": "basket-scoreboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @basket-scoreboard/api",
    "dev:web": "npm run dev --workspace @basket-scoreboard/web",
    "start": "node app.js",
    "build": "tsc -b && npm run build --workspace @basket-scoreboard/web",
    "test": "vitest run",
    "test:db": "vitest run tests/db",
    "lint": "tsc -b --pretty false",
    "db:check": "npm run db:check --workspace @basket-scoreboard/api",
    "migrate": "npm run migrate --workspace @basket-scoreboard/api",
    "migrate:status": "npm run migrate:status --workspace @basket-scoreboard/api",
    "auth:seed": "npm run auth:seed --workspace @basket-scoreboard/api",
    "auth:create-admin": "npm run auth:create-admin --workspace @basket-scoreboard/api",
    "smoke:create-match": "npm run smoke:create-match --workspace @basket-scoreboard/api"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
